generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
model Task {
  id        Int      @id @default(autoincrement())
  title     String
  done      Boolean  @default(false)
  priority  String?
  dueDate   DateTime?
  position  Int      @default(0)
  createdAt DateTime @default(now())
}